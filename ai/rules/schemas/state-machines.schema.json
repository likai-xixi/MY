{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex.my/schemas/state-machines.schema.json",
  "title": "Business state-machine registry",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "entries"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "featureId",
          "entity",
          "statusField",
          "logTable",
          "states",
          "transitions",
          "terminalStates",
          "guards",
          "permissions",
          "idempotency",
          "tests",
          "status"
        ],
        "properties": {
          "states": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "transitions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["from", "to", "action", "permission", "idempotent", "logRequired", "reasonRequired"],
              "properties": {
                "from": {
                  "type": "string"
                },
                "to": {
                  "type": "string"
                },
                "action": {
                  "type": "string"
                },
                "permission": {
                  "type": "string"
                },
                "idempotent": {
                  "type": "boolean"
                },
                "logRequired": {
                  "type": "boolean"
                },
                "reasonRequired": {
                  "type": "boolean"
                },
                "allowedRoles": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "guardRefs": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "tests": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
