{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex.my/schemas/evidence-manifest.schema.json",
  "title": "High-risk evidence manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "evidenceId",
    "featureId",
    "riskDomain",
    "generatedAt",
    "gitCommit",
    "commands",
    "environment",
    "coveredFiles",
    "coveredFileHashes",
    "cases",
    "result",
    "limitations",
    "producedBy"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "evidenceId": {
      "type": "string",
      "minLength": 1
    },
    "featureId": {
      "type": "string",
      "minLength": 1
    },
    "riskDomain": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "gitCommit": {
      "type": "string",
      "minLength": 7
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": ["string", "object"]
      }
    },
    "environment": {
      "type": "object"
    },
    "coveredFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "coveredFileHashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-fA-F0-9]{64}$"
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "result": {
      "enum": ["pass", "fail", "warning", "inconclusive"]
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "producedBy": {
      "type": "string",
      "minLength": 1
    },
    "blocking": {
      "type": "boolean"
    }
  }
}
